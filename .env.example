# Database — Docker fills this automatically
DATABASE_URL="postgresql://subconscious:subconscious_dev@localhost:5432/subconscious"

# NextAuth — generate secret with: openssl rand -hex 32
NEXTAUTH_SECRET="your-32-char-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (console.cloud.google.com)
# Callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Groq (console.groq.com) — FREE
GROQ_API_KEY=""

# Gemini (aistudio.google.com) — FREE
GEMINI_API_KEY=""

# Docker Postgres
POSTGRES_USER=subconscious
POSTGRES_PASSWORD=subconscious_dev
POSTGRES_DB=subconscious

# pgAdmin
PGADMIN_EMAIL=admin@subconscious.app
PGADMIN_PASSWORD=admin
